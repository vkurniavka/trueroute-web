# When unset, Download CTA renders as 'Coming Soon'
NEXT_PUBLIC_PLAY_STORE_URL=

# Cloudflare R2 — used by scripts/build-region.sh and scripts/generate-index.sh
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=trueroute-data

# CDN base URL for index.json asset URLs (used by scripts/generate-index.sh)
CDN_BASE_URL=https://cdn.trueroutenavigation.com
